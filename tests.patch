+"""
+`aggregate_errors=True` aggregates `min_length` and `pattern` failures only. `ascii_only`, `max_length`, `strip_whitespace`, `to_lower`, and `to_upper` all retain existing fail-fast or transform-first behavior. Type-level failures (`string_type`) are always terminal.
+"""
+from __future__ import annotations
+
+from typing import Annotated, Any
+
+import pytest
+from pydantic import BaseModel, Field, TypeAdapter, ValidationError
+from pydantic.plugin import PydanticPluginProtocol, ValidatePythonHandlerProtocol
+import contextlib
+from collections.abc import Generator
+from pydantic.plugin._loader import _plugins, get_plugins
+
+@contextlib.contextmanager
+def install_plugin(plugin: PydanticPluginProtocol) -> Generator[None, None, None]:
+    get_plugins()
+    from pydantic.plugin._loader import _plugins as loader_plugins
+    loader_plugins[plugin.__class__.__qualname__] = plugin
+    try:
+        yield
+    finally:
+        loader_plugins.clear()
+
+class User(BaseModel):
+    username: str
+    
+def test_aggregate_errors_plumbing() -> None:
+    # 1. Verification correction: ensure the test actually fails validation
+    # If the validation unexpectedly passes, pytest.raises will fail the test.
+    with pytest.raises(ValidationError) as exc_info:
+        User.model_validate({"username": 123}, aggregate_errors=True)
+    
+    # 2. Check that the error behavior matches current default behavior 
+    # (only 1 error returned because we haven't implemented aggregation)
+    assert len(exc_info.value.errors()) == 1
+    assert exc_info.value.errors()[0]['type'] == 'string_type'
+
+def test_model_validate_accepts_aggregate_errors_for_valid_input() -> None:
+    # API acceptance test: valid input must succeed silently and return the correct Model
+    user = User.model_validate({"username": "ABCDE"}, aggregate_errors=True)
+    assert user.username == "ABCDE"
+
+def test_aggregate_errors_false_matches_omitted() -> None:
+    with pytest.raises(ValidationError) as exc_omitted:
+        User.model_validate({"username": 123})
+        
+    with pytest.raises(ValidationError) as exc_false:
+        User.model_validate({"username": 123}, aggregate_errors=False)
+        
+    assert exc_omitted.value.errors() == exc_false.value.errors()
+
+def test_aggregate_errors_does_not_leak_between_calls() -> None:
+    # 1. Omitted
+    with pytest.raises(ValidationError) as e1:
+        User.model_validate({"username": 123})
+    assert len(e1.value.errors()) == 1
+    
+    # 2. True (currently acts like False)
+    with pytest.raises(ValidationError) as e2:
+        User.model_validate({"username": 123}, aggregate_errors=True)
+    assert len(e2.value.errors()) == 1
+    
+    # 3. Omitted again
+    with pytest.raises(ValidationError) as e3:
+        User.model_validate({"username": 123})
+    assert len(e3.value.errors()) == 1
+    
+    # 4. False
+    with pytest.raises(ValidationError) as e4:
+        User.model_validate({"username": 123}, aggregate_errors=False)
+    assert len(e4.value.errors()) == 1
+
+def test_type_adapter_accepts_aggregate_errors() -> None:
+    adapter = TypeAdapter(Annotated[str, Field(min_length=5, pattern=r'^[A-Z]+$')])
+    assert adapter.validate_python('ABCDE', aggregate_errors=True) == 'ABCDE'
+
+def test_plugin_without_aggregate_errors_parameter_remains_compatible() -> None:
+    seen: list[dict[str, object]] = []
+
+    class LegacyHandler(ValidatePythonHandlerProtocol):
+        def on_enter(self, input: Any, *, strict: bool | None = None, extra: Any | None = None, from_attributes: bool | None = None, context: Any | None = None, self_instance: Any | None = None, by_alias: bool | None = None, by_name: bool | None = None) -> None:
+            seen.append(
+                {
+                    'strict': strict,
+                    'extra': extra,
+                    'from_attributes': from_attributes,
+                    'context': context,
+                    'by_alias': by_alias,
+                    'by_name': by_name,
+                }
+            )
+
+    class LegacyPlugin(PydanticPluginProtocol):
+        def new_schema_validator(self, *args: Any, **kwargs: Any) -> Any:
+            return LegacyHandler(), None, None
+
+    with install_plugin(LegacyPlugin()):
+        class PluginUser(BaseModel):
+            username: str
+
+        PluginUser.model_validate({'username': 'ABCDE'}, aggregate_errors=True)
+
+    assert len(seen) == 1
+
+def test_single_constraint_still_reports_one_error() -> None:
+    class SecureUser(BaseModel):
+        password: str = Field(min_length=10, pattern=r'^[A-Z]+$')
+
+    # Fails only min_length
+    with pytest.raises(ValidationError) as exc_info:
+        SecureUser.model_validate({"password": "ABCDEFGHI"}, aggregate_errors=True)
+
+    errors = exc_info.value.errors()
+    assert len(errors) == 1
+    assert errors[0]['type'] == 'string_too_short'
+    assert errors[0]['loc'] == ('password',)
+
+def test_string_constraints_aggregation() -> None:
+    # This is the RED test for Phase 2!
+    class SecureUser(BaseModel):
+        # We explicitly use an anchored pattern as advised: ^[A-Z]+$
+        password: str = Field(min_length=10, pattern=r'^[A-Z]+$')
+        
+    # Fails both length and pattern constraints
+    with pytest.raises(ValidationError) as exc_info:
+        SecureUser.model_validate({"password": "abc"}, aggregate_errors=True)
+        
+    errors = exc_info.value.errors()
+    # It should report exactly TWO errors once Phase 2 is complete.
+    # We don't check for ordering of constraints.
+    assert len(errors) == 2
+    assert {error['type'] for error in errors} == {
+        'string_too_short',
+        'string_pattern_mismatch',
+    }
+    assert all(e['loc'] == ('password',) for e in errors)
+
+
+def test_ascii_only_is_terminal_before_aggregation() -> None:
+    """ascii_only fires before min_length/pattern — only one error even with aggregate_errors=True."""
+    from pydantic import StringConstraints
+    class Model(BaseModel):
+        value: Annotated[str, StringConstraints(min_length=10, pattern=r'^[A-Z]+$', ascii_only=True)]
+
+    with pytest.raises(ValidationError) as exc_info:
+        Model.model_validate({'value': 'αβγ'}, aggregate_errors=True)
+
+    # Only string_not_ascii — this is CORRECT, not a bug
+    assert len(exc_info.value.errors()) == 1
+    assert exc_info.value.errors()[0]['type'] == 'string_not_ascii'
+
+def test_aggregate_mode_does_not_affect_max_length() -> None:
+    """max_length retains fail-fast; pattern is never evaluated when max_length fails."""
+    class Model(BaseModel):
+        value: str = Field(max_length=3, pattern=r'^[A-Z]+$')
+
+    with pytest.raises(ValidationError) as exc_info:
+        Model.model_validate({'value': 'abcdefg'}, aggregate_errors=True)
+
+    assert len(exc_info.value.errors()) == 1
+    assert exc_info.value.errors()[0]['type'] == 'string_too_long'
+
+def test_aggregate_errors_with_strip_whitespace() -> None:
+    """Verify that strip_whitespace is applied before constraint checks in aggregate mode."""
+    from pydantic import StringConstraints
+    class Model(BaseModel):
+        value: Annotated[str, StringConstraints(min_length=10, pattern=r'^[A-Z]+$', strip_whitespace=True)]
+
+    # "  abc  " strips to "abc" (3 chars) — violates both min_length and pattern
+    with pytest.raises(ValidationError) as exc_info:
+        Model.model_validate({'value': '  abc  '}, aggregate_errors=True)
+
+    types = {e['type'] for e in exc_info.value.errors()}
+    assert types == {'string_too_short', 'string_pattern_mismatch'}
+
+def test_json_parity() -> None:
+    class Model(BaseModel):
+        value: str = Field(min_length=10, pattern=r'^[A-Z]+$')
+
+    with pytest.raises(ValidationError) as exc_info:
+        Model.model_validate_json('{"value": "abc"}', aggregate_errors=True)
+
+    types = {e['type'] for e in exc_info.value.errors()}
+    assert types == {'string_too_short', 'string_pattern_mismatch'}
+
+def test_strict_mode_parity() -> None:
+    class Model(BaseModel):
+        value: str = Field(min_length=10, pattern=r'^[A-Z]+$')
+
+    with pytest.raises(ValidationError) as exc_info:
+        Model.model_validate({'value': 123}, strict=True, aggregate_errors=True)
+
+    types = {e['type'] for e in exc_info.value.errors()}
+    assert types == {'string_type'}
+
+@pytest.mark.parametrize(
+    'value',
+    [
+        123,
+        '',
+        'abc',
+        'ABCDEFGHIJK',
+        '  abc  ',
+    ],
+)
+def test_aggregate_errors_false_matches_omitted_for_strings(value: object) -> None:
+    from pydantic import StringConstraints
+    class Model(BaseModel):
+        value: Annotated[str, StringConstraints(min_length=5, max_length=10, pattern=r'^[A-Z]+$')]
+
+    def get_errors(kwargs: dict[str, object]) -> list[dict[str, object]]:
+        with pytest.raises(ValidationError) as exc_info:
+            Model.model_validate({'value': value}, **kwargs)
+        return exc_info.value.errors()
+
+    assert get_errors({}) == get_errors({'aggregate_errors': False})
+
+def test_model_validate_strings_aggregates() -> None:
+    from pydantic import StringConstraints
+    class Model(BaseModel):
+        value: Annotated[str, StringConstraints(min_length=10, pattern=r'^[A-Z]+$')]
+
+    with pytest.raises(ValidationError) as exc_info:
+        Model.model_validate_strings({'value': 'abc'}, aggregate_errors=True)
+
+    assert {e['type'] for e in exc_info.value.errors()} == {
+        'string_too_short', 'string_pattern_mismatch'
+    }
+
+def test_type_adapter_validate_json_aggregates() -> None:
+    from typing import Annotated
+    from pydantic import StringConstraints
+    ta = TypeAdapter(Annotated[str, StringConstraints(min_length=10, pattern=r'^[A-Z]+$')])
+    with pytest.raises(ValidationError) as exc_info:
+        ta.validate_json('"abc"', aggregate_errors=True)
+    assert {e['type'] for e in exc_info.value.errors()} == {
+        'string_too_short', 'string_pattern_mismatch'
+    }
+
+def test_type_adapter_validate_strings_aggregates() -> None:
+    from typing import Annotated
+    from pydantic import StringConstraints
+    ta = TypeAdapter(Annotated[str, StringConstraints(min_length=10, pattern=r'^[A-Z]+$')])
+    with pytest.raises(ValidationError) as exc_info:
+        ta.validate_strings('abc', aggregate_errors=True)
+    assert {e['type'] for e in exc_info.value.errors()} == {
+        'string_too_short', 'string_pattern_mismatch'
+    }
+
+def test_aggregate_errors_valid_input_returns_no_errors() -> None:
+    """Aggregation path must not return an empty error vector on success."""
+    from pydantic import StringConstraints
+    class Model(BaseModel):
+        value: Annotated[str, StringConstraints(min_length=3, pattern=r'^[A-Z]+$')]
+    result = Model.model_validate({'value': 'ABC'}, aggregate_errors=True)
+    assert result.value == 'ABC'
